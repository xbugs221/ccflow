{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "outDir": "dist-node",
    "rootDir": ".",
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": false,
    "types": ["node"],
    "declaration": false,
    "sourceMap": true
  },
  "include": [
    "server/**/*.ts",
    "server/**/*.d.ts",
    "shared/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "tests"
  ]
}
